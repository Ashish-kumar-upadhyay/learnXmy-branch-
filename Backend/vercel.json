{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/[...path].ts",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    },
    "api/[...path].ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/[...path]"
    }
  ],
  "env": {
    "CORS_ORIGIN": "*"
  }
}
